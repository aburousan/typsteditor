{
  "name": "hilbert-editor",
  "private": true,
  "version": "0.1.2",
  "description": "Hilbert — an offline editor for Typst (Unofficial), aimed at maths/physics writing.",
  "author": "Kazi Abu Rousan",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/aburousan/hilbert-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/aburousan/hilbert-editor.git"
  },
  "bugs": {
    "url": "https://github.com/aburousan/hilbert-editor/issues"
  },
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron .",
    "app": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.kaziaburousan.hilbert",
    "productName": "Hilbert",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist/**",
      "server.js",
      "electron/**",
      "electron/typst-packages/**",
      "package.json"
    ],
    "afterPack": "electron/afterPack.cjs",
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "maintainer": "Kazi Abu Rousan"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react-image-crop": "^11.1.2"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "monaco-editor": "^0.55.1",
    "oxlint": "^1.71.0",
    "pdfjs-dist": "^4.10.38",
    "puppeteer": "^25.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "keywords": [
    "typst",
    "editor",
    "latex-alternative",
    "physics",
    "math",
    "pdf",
    "electron",
    "offline",
    "monaco",
    "cetz"
  ]
}
