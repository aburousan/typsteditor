{
  "name": "hilbert-editor",
  "private": true,
  "version": "0.1.6",
  "description": "Hilbert: an offline editor for Typst (Unofficial), aimed at maths/physics writing.",
  "author": "Kazi Abu Rousan",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/aburousan/hilbert-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/aburousan/hilbert-editor.git"
  },
  "bugs": {
    "url": "https://github.com/aburousan/hilbert-editor/issues"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,api \"vite\" \"npm run dev:api\"",
    "dev:api": "cd src-tauri && PORT=3001 cargo run -- --headless",
    "desktop": "npm run build && cd src-tauri && cargo run",
    "build": "tsc -b && vite build && node scripts/strip-bundled-secrets.mjs",
    "test:backend": "cd src-tauri && cargo test",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "react-image-crop": "^11.1.2"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "monaco-editor": "^0.55.1",
    "oxlint": "^1.71.0",
    "pdfjs-dist": "^4.10.38",
    "puppeteer": "^25.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "keywords": [
    "typst",
    "editor",
    "latex-alternative",
    "physics",
    "math",
    "pdf",
    "offline",
    "monaco",
    "cetz"
  ]
}
