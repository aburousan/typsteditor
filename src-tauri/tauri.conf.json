{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typst Editor",
  "version": "0.1.1",
  "identifier": "com.kaziaburousan.typsteditor",
  "build": {
    "frontendDist": "ui-dummy"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/dist": "dist",
      "resources/typst-packages": "typst-packages"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
